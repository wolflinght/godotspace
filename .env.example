# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# Gemini API Key（从 https://aistudio.google.com/app/apikey 获取）
GEMINI_API_KEY=your_gemini_api_key_here

# Database（服务端读取；也可用同名系统环境变量覆盖）
STARRIVER_DB_HOST=127.0.0.1
STARRIVER_DB_PORT=3306
STARRIVER_DB_NAME=starriver
STARRIVER_DB_USER=starriver
STARRIVER_DB_PASSWORD=your_database_password_here
